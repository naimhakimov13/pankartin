---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductHero from '../components/ProductHero.astro';
import PackCard from '../components/PackCard.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import FuncGrid from '../components/FuncGrid.astro';
import Compo from '../components/Compo.astro';
import Checklist from '../components/Checklist.astro';
import IndGroup from '../components/IndGroup.astro';
import IndList from '../components/IndList.astro';
import Split from '../components/Split.astro';
import InfoCard from '../components/InfoCard.astro';
import DataTable from '../components/DataTable.astro';
import PromoBanner from '../components/PromoBanner.astro';
import CtaBand from '../components/CtaBand.astro';
import { products } from '../data/products';

const product = products.find((p) => p.slug === 'pannevrol')!;
---
<BaseLayout
  theme={product.theme}
  active={product.slug}
  productDisclaimer
  title="Pannevrol — нейропротектор для головного и периферического мозга | PanPharm"
  description="Pannevrol — комплекс с цитиколином, гинкго билоба, фосфолипидами и витаминами группы B. Восстанавливает миелиновую оболочку, улучшает память и концентрацию, поддерживает психоэмоциональный статус."
>
  <ProductHero
    product={product}
    badge="Цитиколин · Гинкго Билоба · Фосфолипиды · Витамины B"
    slogan="«Восстанавливает нервные клетки и улучшает нервные импульсы»"
    description="Нейропротектор для головного и периферического мозга. Pannevrol — препарат выбора при заболеваниях нервной системы: восстанавливает миелиновую оболочку, улучшает когнитивные функции и поддерживает психоэмоциональный статус."
    primary={{ href: '#sostav', label: 'Состав препарата' }}
    secondary={{ href: '#dozirovka', label: 'Как принимать' }}
  >
    <PackCard
      name="Pannevrol"
      sub="Нейропротектор · 11 активных компонентов"
      items={[
        { name: 'Цитиколин',                 value: '100 мг'  },
        { name: 'Инозитол',                  value: '100 мг'  },
        { name: 'Диметилглицин гидрохлорид', value: '100 мг'  },
        { name: 'Фосфатидилхолин 20%',       value: '50 мг'   },
        { name: 'Гинкго Билоба',             value: '50 мг'   },
        { name: 'Фолиевая кислота',          value: '200 мкг' },
      ]}
      form="Форма выпуска: 30 таблеток"
      formIcon="pill"
    />
  </ProductHero>

  <PromoBanner
    image="/pannevrol.jpeg"
    alt="Упаковка Pannevrol — 30 таблеток"
    eyebrow="Pannevrol"
    title="Восстанавливает нервные клетки"
    description="Нейропротектор для головного и периферического мозга: цитиколин, гинкго билоба, фосфолипиды и витамины группы B в одной формуле."
  />

  <Section>
    <SectionHead
      center
      eyebrow="Главное"
      title="Pannevrol содержит незаменимые факторы для клеток головного мозга"
      lead="Пять направлений действия на нервную систему — от стимуляции мышления до защиты от ишемии."
    />
    <FuncGrid
      cols={3}
      items={[
        { icon: 'brain',       title: 'Стимулирует',     text: 'Работу мозга, повышает мыслительные способности, концентрацию внимания и память.' },
        { icon: 'shield',      title: 'Защищает',        text: 'Клетки мозга от старения и ишемических повреждений.' },
        { icon: 'refresh-ccw', title: 'Восстанавливает', text: 'Мембраны клеток и повреждённую миелиновую оболочку нервов.' },
        { icon: 'zap',         title: 'Необходим',       text: 'Для обеспечения энергией мозга и мышц.' },
        { icon: 'droplets',    title: 'Улучшает',        text: 'Функции печени и стимулирует выведение токсичных веществ.' },
        { icon: 'scale',       title: 'Участвует',       text: 'В регуляции липидного и углеводного обмена.' },
      ]}
    />
  </Section>

  <Section soft id="sostav">
    <SectionHead
      eyebrow="Состав"
      title="Содержание активных веществ в 1 таблетке"
      lead="Сбалансированный комплекс фосфолипидов, нейрометаболиков и витаминов группы B с максимальным содержанием активного вещества."
    />
    <Compo
      cols={2}
      items={[
        { value: '100 мг',  label: 'Цитиколин'                  },
        { value: '100 мг',  label: 'Инозитол'                    },
        { value: '100 мг',  label: 'Диметилглицин гидрохлорид'   },
        { value: '50 мг',   label: 'Фосфатидилхолин (20%)'       },
        { value: '50 мг',   label: 'Гинкго Билоба'                },
        { value: '30%',     label: 'Фосфатидилсерин'              },
        { value: '1,4 мг',  label: 'Витамин B2'                   },
        { value: '1,4 мг',  label: 'Витамин B6'                   },
        { value: '1,1 мг',  label: 'Витамин B1'                   },
        { value: '2 мкг',   label: 'Витамин B12'                  },
        { value: '200 мкг', label: 'Фолиевая кислота'             },
      ]}
    />
  </Section>

  <Section>
    <SectionHead
      eyebrow="Показания к применению"
      title="Когда назначают Pannevrol"
      lead="Препарат выбора при широком спектре заболеваний центральной и периферической нервной системы."
    />
    <IndGroup
      title="Нарушения мозгового кровообращения"
      items={[
        'Преходящие нарушения мозгового кровообращения',
        'Инсульт и его последствия',
        'Начальные проявления недостаточности кровоснабжения мозга',
        'Дисциркуляторная энцефалопатия',
      ]}
    />
    <IndGroup
      title="Когнитивные нарушения"
      cols
      items={[
        'Нарушение памяти и концентрации внимания',
        'Снижение мышления и скорости реакции',
        'Старческое слабоумие (деменция)',
        'Детский церебральный паралич (ДЦП)',
      ]}
    />
    <IndGroup
      title="Травмы и поражения нервов"
      items={[
        'Черепно-мозговые травмы (в том числе родовые) и их последствия',
        'Сенситивные и моторные расстройства при церебральной патологии',
        'Повреждения черепно-мозговых нервов: тригеминиты, невриты лицевого нерва',
        'Поражения нервных корешков и сплетений: радикулопатии, люмбаго, ишиас, межрёберные миалгии',
      ]}
    />
    <IndGroup
      title="Периферическая нервная система"
      cols
      items={[
        'Нейропатии: диабетическая, алкогольная и др.',
        'Туннельные синдромы периферических нервов',
        'Гипоксически-ишемическая энцефалопатия новорождённых',
        'Опоясывающий лишай',
      ]}
    />
  </Section>

  <Section soft id="dozirovka">
    <Split>
      <div slot="left">
        <span class="eyebrow">Способ применения и дозы</span>
        <h2>Как принимать Pannevrol</h2>
        <p class="lead" style="margin-top:14px">
          Рекомендуемая суточная доза для взрослых — <b>1 таблетка в день</b>,
          желательно во время еды, запивая достаточным количеством воды.
        </p>
        <IndList
          style="margin-top:20px"
          items={[
            'Принимать по 1 таблетке в день во время еды',
            'Продолжительность приёма — не менее 1 месяца',
            'При необходимости курс можно повторить через 1 месяц',
          ]}
        />
      </div>
      <InfoCard slot="right" accent title="Кратко о приёме">
        <ul class="pack-list">
          <li><span>Суточная доза</span><b>1 таблетка</b></li>
          <li><span>Время приёма</span><b>во время еды</b></li>
          <li><span>Минимальный курс</span><b>1 месяц</b></li>
          <li><span>Повторный курс</span><b>через 1 месяц</b></li>
          <li><span>Форма выпуска</span><b>30 таблеток</b></li>
        </ul>
      </InfoCard>
    </Split>
  </Section>

  <Section>
    <SectionHead
      center
      eyebrow="Механизм действия"
      title="Pannevrol восстанавливает повреждённую миелиновую оболочку"
      lead="В основе заболеваний периферической нервной системы стоят повреждения миелиновой оболочки — главного «изолятора» нервного волокна."
    />
    <Split>
      <InfoCard slot="left" icon="turtle" title="Повреждённый нерв · 4 км/ч">
        <p style="color:var(--muted);margin-top:10px">
          Разрушение миелина приводит к резкому падению скорости нервной
          проводимости. Импульс «застревает» — отсюда онемение, слабость,
          нарушения чувствительности и моторики.
        </p>
      </InfoCard>
      <InfoCard slot="right" accent icon="zap" title="Здоровый нерв · 400 км/ч">
        <p style="color:var(--muted);margin-top:10px">
          Pannevrol участвует в синтезе мембранных фосфолипидов — без
          снижения резервов ацетилхолина. Восстанавливается миелин,
          возвращается нормальная скорость проведения импульса и связь
          между нейронами.
        </p>
      </InfoCard>
    </Split>
    <Checklist
      items={[
        'Улучшает метаболическую и нейромедиаторную активность нейронов даже при ишемии и гипогликемии',
        'Ускоряет регенерацию нервных путей после травматического разрушения ткани',
        'Стимулирует синтез норадреналина, дофамина и серотонина',
        'Увеличивает межнейрональные связи и улучшает когнитивные функции',
        'Предотвращает развитие отёка мозга — уменьшение в гиппокампе на 75,7%, в стриатуме на 69,7%',
        'Участвует в синтезе фосфатидилхолина, фосфатидилсерина, фосфатидилэтаноламина',
      ]}
    />
  </Section>

  <Section soft>
    <SectionHead
      center
      eyebrow="Психоэмоциональный статус"
      title="Зависимость психоэмоционального статуса от уровня дофамина"
      lead="Pannevrol помогает выровнять уровень дофамина — ключевого нейромедиатора, отвечающего за настроение, мотивацию и контроль поведения."
    />
    <Split>
      <InfoCard slot="left" title="⬆️ Повышенный уровень дофамина">
        <IndList
          style="margin-top:14px"
          items={[
            'Нервная возбудимость',
            'Бессонница',
            'Галлюцинации',
            'Маниакальный бред',
            'Психоз',
            'Бессвязные мысли',
          ]}
        />
      </InfoCard>
      <InfoCard slot="right" title="⬇️ Сниженный уровень дофамина">
        <IndList
          style="margin-top:14px"
          items={[
            'Абулия (отсутствие воли)',
            'Депрессия',
            'Сонливость',
            'Бессвязные негативные мысли',
            'Тревожность',
            'Экстрапирамидальные расстройства, каталепсия',
          ]}
        />
      </InfoCard>
    </Split>
  </Section>

  <Section>
    <SectionHead
      center
      eyebrow="Результаты исследования"
      title="Уменьшение отёка мозга на фоне приёма Pannevrol"
      lead="По данным Journal of Molecular Neuroscience (2005) — содержащийся в Pannevrol цитиколин достоверно снижает отёк мозга в ключевых структурах."
    />
    <DataTable
      headers={['Структура мозга', 'Уменьшение отёка']}
      rows={[
        ['Гиппокамп', '75,7%'],
        ['Стриатум',  '69,7%'],
      ]}
    />
    <p class="lead" style="margin-top:14px;font-size:.9rem">
      Источники: Journal of Molecular Neuroscience, September 2005, Volume 27,
      Issue 1, pp 137–145; Shruti V. Kabadi and Timothy J. Maher,
      «Annals of the New York Academy of Sciences».
    </p>
  </Section>

  <CtaBand
    title="Препарат выбора при заболеваниях нервной системы"
    description="Восстановите нервные клетки, улучшите когнитивные функции и психоэмоциональный статус вместе с Pannevrol."
  >
    <a href="/#contacts" class="btn btn-white">Где купить</a>
    <a href="/#products" class="btn btn-outline-white">Вся продукция</a>
  </CtaBand>
</BaseLayout>
