---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductHero from '../components/ProductHero.astro';
import PackCard from '../components/PackCard.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import FuncGrid from '../components/FuncGrid.astro';
import Compo from '../components/Compo.astro';
import Checklist from '../components/Checklist.astro';
import IndList from '../components/IndList.astro';
import DataTable from '../components/DataTable.astro';
import Split from '../components/Split.astro';
import InfoCard from '../components/InfoCard.astro';
import PromoBanner from '../components/PromoBanner.astro';
import CtaBand from '../components/CtaBand.astro';
import { Icon } from 'astro-icon/components';
import { products } from '../data/products';

const product = products.find((p) => p.slug === 'metfolipan')!;
---
<BaseLayout
  theme={product.theme}
  active={product.slug}
  productDisclaimer
  title="MetfoliPan — метилфолат, витамины B6 и B12 | PanPharm"
  description="MetfoliPan — активная форма фолиевой кислоты (метилфолат 400 мкг) с витаминами B6 и B12. Для женщин, планирующих беременность, при анемии и в косметологии."
  image="/metfolipan.jpeg"
  ogType="article"
>
  <ProductHero
    product={product}
    badge="Метилфолат · Витамин B6 · Витамин B12"
    slogan="«Активная форма фолиевой кислоты — без биотрансформации!»"
    description="Метилфолат — готовая активная форма фолиевой кислоты, которая усваивается напрямую. В сочетании с витаминами B6 и B12 обеспечивает поддержку при планировании беременности, анемии и повышенной утомляемости."
    primary={{ href: '#sostav', label: 'Состав препарата' }}
    secondary={{ href: '#dozirovka', label: 'Как принимать' }}
  >
    <PackCard
      name="MetfoliPan"
      sub="Метилфолат · B6 · B12"
      items={[
        { name: 'Метилфолат (B9)', value: '400 мкг' },
        { name: 'Витамин B6',      value: '1,3 мг'  },
        { name: 'Витамин B12',     value: '0,5 мкг' },
      ]}
      form="Форма выпуска: таблетки"
      formIcon="pill"
    />
  </ProductHero>

  <PromoBanner
    image="/metfolipan.jpeg"
    alt="Упаковка MetfoliPan — 30 таблеток"
    eyebrow="MetfoliPan"
    title="Активный метилфолат — без биотрансформации"
    description="Готовая активная форма фолиевой кислоты с витаминами B6 и B12. Усваивается напрямую — даже при сниженной активности фермента MTHFR."
  />

  <Section>
    <SectionHead
      center
      eyebrow="В чём отличие"
      title="Активный метилфолат — без биотрансформации"
      lead="Уникальный компонент MetfoliPan — активная форма фолиевой кислоты, которая не требует дополнительного превращения в организме и сразу включается в обменные процессы."
    />
    <FuncGrid
      cols={3}
      items={[
        { icon: 'zap',  title: 'Усваивается напрямую',   text: 'Метилфолат работает даже при сниженной активности фермента MTHFR, в отличие от обычной фолиевой кислоты.' },
        { icon: 'baby', title: 'Защита будущего малыша', text: 'Снижает риск дефектов нервной трубки и сердечно-сосудистых пороков у плода на ранних сроках.' },
        { icon: 'dna',  title: 'Синергия витаминов B',   text: 'B6 и B12 усиливают действие фолата и помогают нормализовать уровень гомоцистеина.' },
      ]}
    />
  </Section>

  <Section soft id="sostav">
    <SectionHead
      eyebrow="Состав"
      title="Действующие вещества в одной таблетке"
      lead="Сбалансированная формула: активный фолат и две опоры из группы витаминов B."
    />
    <Compo
      cols={3}
      items={[
        { value: '400 мкг', label: 'Метилфолат (Витамин B9)' },
        { value: '1,3 мг',  label: 'Витамин B6'              },
        { value: '0,5 мкг', label: 'Витамин B12'             },
      ]}
    />
  </Section>

  <Section>
    <SectionHead
      eyebrow="Признаки дефицита"
      title="Когда организму не хватает фолиевой кислоты"
      lead="Эти симптомы могут указывать на дефицит фолата и витаминов группы B — повод задуматься о приёме MetfoliPan."
    />
    <Checklist
      items={[
        'Повышенный уровень гомоцистеина в крови',
        'Анемия с повышенным количеством эритроцитов',
        'Постоянное чувство усталости и слабость',
        'Повышенная раздражительность',
        'Одышка при привычных нагрузках',
        'Бледность кожных покровов',
      ]}
    />
  </Section>

  <Section soft>
    <SectionHead
      eyebrow="Показания к применению"
      title="Когда назначают MetfoliPan"
      lead="Особенно часто препарат назначают женщинам в период беременности и лактации, а также тем, кто длительно принимает противозачаточные средства."
    />
    <IndList
      cols
      items={[
        'Мегалобластная анемия от недостатка фолиевой кислоты',
        'Хронический гастроэнтерит — воспаление слизистых ЖКТ',
        'Эпилепсия, сопровождающаяся судорогами',
        'Беременность, лактация, период планирования',
        'Длительный приём противозачаточных средств',
        'Псориаз и некоторые кожные заболевания',
        'Психические расстройства и депрессивные состояния',
        'Алкогольная интоксикация',
        'Интенсивные физические и умственные нагрузки',
        'В комплексе с метотрексатом — для восполнения фолатов',
      ]}
    />
  </Section>

  <Section id="dozirovka">
    <SectionHead
      eyebrow="Способ применения и дозы"
      title="Как принимать MetfoliPan"
      lead="Препарат принимают внутрь во время еды. Дозировка зависит от показаний и определяется специалистом."
    />
    <DataTable
      headers={['Назначение', 'Суточная доза']}
      rows={[
        ['Женщинам, планирующим беременность, и до 12-й недели беременности', '1 таблетка в день'],
        ['При других заболеваниях по показаниям',                              '2–3 таблетки в день'],
        ['В косметологии — против выпадения волос',                            '1 таблетка в день'],
      ]}
    />
    <p class="lead" style="margin-top:14px;font-size:.92rem">
      <b>Противопоказания:</b> индивидуальная непереносимость компонентов.
      Перед применением проконсультируйтесь со специалистом.
    </p>
  </Section>

  <Section soft>
    <Split>
      <div slot="left">
        <span class="eyebrow">Для будущих мам</span>
        <h2>В период планирования и вынашивания ребёнка</h2>
        <p class="lead" style="margin-top:14px">
          Фолиевая кислота играет ключевую роль в развитии плода. Её приём
          нужно начинать <b>до зачатия</b> и продолжать в I триместре, пока
          закладываются все органы и системы ребёнка.
        </p>
        <IndList
          style="margin-top:20px"
          items={[
            'Участвует в формировании нервной системы плода',
            'Уменьшает риск дефектов нервной трубки и пороков сердца',
            'Способствует снижению риска преждевременных родов',
            'Стимулирует кроветворение и созревание эритроцитов',
            'Поддерживает нормальное развитие органов и тканей',
          ]}
        />
      </div>
      <InfoCard slot="right" accent title="Почему именно метилфолат">
        <p style="color:var(--muted);margin-top:10px">
          У части женщин фермент MTHFR работает не в полную силу — обычная
          фолиевая кислота плохо превращается в активную форму. <b>Метилфолат</b>
          уже активен и усваивается напрямую.
        </p>
        <p style="margin-top:14px">
          <b>Приём фолатов в комплексе с витаминами группы B</b> снижает риск
          развития ДНТ эффективнее, чем монопрепараты фолиевой кислоты.
        </p>
        <p style="margin-top:16px;background:#fff;border-radius:12px;padding:14px 16px;font-weight:700;color:var(--accent);line-height:1.45">
          <Icon name="lucide:globe" class="inline-icon" />В мире рождается около <b>300 000</b> детей в год с дефектами
          нервной трубки — большую часть случаев можно предотвратить.
        </p>
      </InfoCard>
    </Split>
  </Section>

  <Section>
    <SectionHead
      center
      eyebrow="Не только для здоровья"
      title="MetfoliPan в косметологии"
      lead="Фолиевая кислота снижает риск облысения, стимулирует рост и регенерацию клеток, помогает отсрочить появление седины. Для красоты волос достаточно 1 таблетки в день."
    />
    <FuncGrid
      cols={3}
      items={[
        { icon: 'scissors', title: 'Против выпадения',   text: 'Поддерживает фолликулы и помогает локонам вернуть силу и блеск.' },
        { icon: 'sprout',   title: 'Рост и регенерация', text: 'Стимулирует обновление клеток кожи и волосяных луковиц.'         },
        { icon: 'sparkles', title: 'Отсрочка седины',    text: 'Помогает дольше сохранять естественный пигмент волос.'           },
      ]}
    />
  </Section>

  <CtaBand
    title="Поддержка с самого начала жизни"
    description="MetfoliPan — активный метилфолат, витамины B6 и B12 в одной формуле для женщин, будущих мам и всех, кому важно здоровье и энергия."
  >
    <a href="/#contacts" class="btn btn-white">Где купить</a>
    <a href="/#products" class="btn btn-outline-white">Вся продукция</a>
  </CtaBand>
</BaseLayout>
