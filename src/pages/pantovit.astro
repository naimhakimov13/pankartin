---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductHero from '../components/ProductHero.astro';
import PackCard from '../components/PackCard.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import FuncGrid from '../components/FuncGrid.astro';
import Compo from '../components/Compo.astro';
import IndGroup from '../components/IndGroup.astro';
import IndList from '../components/IndList.astro';
import DataTable from '../components/DataTable.astro';
import Split from '../components/Split.astro';
import InfoCard from '../components/InfoCard.astro';
import PromoBanner from '../components/PromoBanner.astro';
import CtaBand from '../components/CtaBand.astro';
import { products } from '../data/products';

const product = products.find((p) => p.slug === 'pantovit')!;
---
<BaseLayout
  theme={product.theme}
  active={product.slug}
  productDisclaimer
  title="PantoVit — витамины D3 и K2 в каплях для всей семьи | PanPharm"
  description="PantoVit — оптимальная дозировка витаминов D3 и K2 в каплях. Кальций без K2 не строит кость — синергия компонентов работает на крепкие кости и сосуды. Для детей, взрослых и беременных."
  image="/pantovit.jpeg"
  ogType="article"
>
  <ProductHero
    product={product}
    badge="Витамин D₃ · Витамин K₂"
    slogan="«Пусть всегда будет солнце!»"
    description="PantoVit — оптимальная дозировка витаминов D₃ и K₂ в одной формуле. Доказано: кальций и витамин D₃ без участия витамина K₂ не способны обеспечить полноценное построение кости."
    primary={{ href: '#sostav', label: 'Состав препарата' }}
    secondary={{ href: '#dozirovka', label: 'Дозировка по возрасту' }}
  >
    <PackCard
      name="PantoVit"
      sub="D₃ + K₂ для всей семьи"
      items={[
        { name: 'Витамин D₃', value: '400 МЕ' },
        { name: 'Витамин K₂', value: '1,2 МЕ' },
      ]}
      form="Форма выпуска: капли 30 мл"
      formIcon="droplet"
    />
  </ProductHero>

  <PromoBanner
    image="/pantovit.jpeg"
    alt="Упаковка PantoVit — капли 30 мл"
    eyebrow="PantoVit"
    title="«Пусть всегда будет солнце!»"
    description="Витамины D₃ и K₂ в одной формуле — синергия для крепких костей, здоровья сердца и сосудов и сильного иммунитета."
  />

  <Section>
    <SectionHead
      center
      eyebrow="Главное"
      title="Что даёт PantoVit"
      lead="Сбалансированная пара D₃ + K₂ направляет кальций именно туда, где он нужен: в кости и зубы, а не в сосуды и мягкие ткани."
    />
    <FuncGrid
      cols={3}
      items={[
        { icon: 'bone',          title: 'Крепкие кости',      text: 'D₃ регулирует усвоение кальция и фосфора, а K₂ направляет минералы в костную ткань.' },
        { icon: 'heart-pulse',   title: 'Сердце и сосуды',    text: 'K₂ предотвращает кальцификацию сосудов, помогая нормальной работе сердечно-сосудистой системы.' },
        { icon: 'shield-check',  title: 'Иммунитет и обмен',  text: 'D₃ стимулирует иммунную систему, регулирует метаболизм инсулина и глюкозы.' },
      ]}
    />
  </Section>

  <Section soft id="sostav">
    <SectionHead
      eyebrow="Состав"
      title="Оптимальная дозировка в каждой капле"
      lead="Минимальный комплекс — максимальный эффект. Доказано, что без K₂ витамин D₃ и кальций не способны построить полноценную кость."
    />
    <Compo
      cols={2}
      items={[
        { value: '400 МЕ', label: 'Витамин D₃' },
        { value: '1,2 МЕ', label: 'Витамин K₂' },
      ]}
    />
    <div class="split" style="margin-top:36px">
      <InfoCard accent icon="sun" title="Витамин D₃">
        <p style="color:var(--muted);margin-top:10px">
          Регулирует обмен кальция и фосфора, стимулирует иммунную систему,
          участвует в работе репродуктивной системы мужчин и женщин,
          поддерживает нервную систему, тонус мышц, нормализует работу
          сердца и сосудов.
        </p>
      </InfoCard>
      <InfoCard icon="arrow-down-to-line" title="Витамин K₂">
        <p style="color:var(--muted);margin-top:10px">
          Активирует белки, которые «направляют» кальций именно в костную
          ткань. Без K₂ кальций может откладываться в стенках сосудов,
          увеличивая риск сердечно-сосудистых заболеваний.
        </p>
      </InfoCard>
    </div>
  </Section>

  <Section>
    <SectionHead
      eyebrow="Показания к применению"
      title="Когда особенно нужен витамин D"
      lead="Витамин D показан всем возрастным группам — от новорождённых до пожилых. Особенно нуждаются пациенты со следующими состояниями."
    />
    <IndGroup
      title="Костно-мышечная система"
      items={[
        'Остеопороз, остеопения, остеомаляция, саркопения',
        'Рахит и миопатия',
      ]}
    />
    <IndGroup
      title="Сердечно-сосудистые и эндокринные"
      cols
      items={[
        'Атеросклероз, стенокардия, инфаркт миокарда',
        'Гипертоническая болезнь',
        'Сахарный диабет 1 и 2 типа',
        'Инсулинорезистентность, вторичный гиперпаратиреоз',
      ]}
    />
    <IndGroup
      title="Иммунитет и инфекции"
      cols
      items={[
        'ОРВИ, ОРЗ, грипп',
        'Туберкулёз, саркоидоз, вирусные гепатиты',
        'Атопический дерматит, бронхиальная астма',
        'Аутоиммунные заболевания: рассеянный склероз, РА, СКВ, псориаз',
      ]}
    />
    <IndGroup
      title="Прочие состояния"
      cols
      items={[
        'Онкологические заболевания (повышает выживаемость)',
        'Метаболический синдром',
        'Целиакия, муковисцидоз, ВЗК, печёночная недостаточность',
        'Хроническое заболевание почек',
      ]}
    />
  </Section>

  <Section soft id="dozirovka">
    <SectionHead
      eyebrow="Способ применения и дозы"
      title="Дозировка по возрасту и состоянию"
      lead="Дозировку всегда лучше согласовать со специалистом и при возможности — с уровнем 25(OH)D в крови."
    />
    <DataTable
      headers={['Категория', 'Суточная доза']}
      rows={[
        ['Дети и взрослые старше 14 лет', '4–5 капель 1 раз в день'],
        ['Летом (достаточно солнца)',     '600 МЕ (2 капли) в сутки'],
        ['Беременные женщины',            '600 МЕ в сутки весь срок'],
        ['Беременные с 28-й недели',      '1200 МЕ в сутки'],
        ['В постменопаузе',                '600–1200 МЕ (2–4 капли) в сутки'],
      ]}
    />
  </Section>

  <Section>
    <SectionHead
      center
      eyebrow="Для женщин и мужчин"
      title="Витамин D — это больше, чем «солнечный витамин»"
      lead="D₃ влияет на репродуктивную систему, гормональный баланс и общее самочувствие — у обоих полов."
    />
    <Split>
      <InfoCard slot="left" icon="user" title="Для женщин">
        <IndList
          style="margin-top:14px"
          items={[
            'Замедляет процессы старения',
            'Избавляет от хронической усталости',
            'Хорошо влияет на зрение и память',
            'Способствует зачатию и нормальному вынашиванию ребёнка',
            'Помогает восстановлению организма после родов',
          ]}
        />
      </InfoCard>
      <InfoCard slot="right" icon="dumbbell" title="Для мужчин">
        <IndList
          style="margin-top:14px"
          items={[
            'Поддерживает опорно-двигательный аппарат при высоких нагрузках',
            'Снижает риск заболеваний предстательной железы',
            'Профилактика мужского бесплодия',
            'Помогает поддерживать высокий уровень тестостерона',
          ]}
        />
      </InfoCard>
    </Split>
  </Section>

  <Section soft>
    <SectionHead
      center
      eyebrow="Клинические данные"
      title="Состояние новорождённых от матерей, получавших и не получавших витамин D"
      lead="Сравнительная характеристика: 4000 МЕ/сут витамина D в период беременности vs контроль."
    />
    <DataTable
      headers={['Показатель новорождённого', 'С витамином D', 'Без витамина D']}
      rows={[
        ['Оценка по шкале Апгар 8–10 баллов', '89,5%', '53,3%'],
        ['Церебральная ишемия',                '10,5%', '46,7%'],
        ['Синдром задержки развития плода',    '5,2%',  '23,3%'],
        ['Синдром гипервозбудимости',          '7,9%',  '36,6%'],
        ['Внутриутробная инфекция',            '2,6%',  '23,3%'],
        ['Гипербилирубинемия',                  '5,2%',  '7,9%'],
      ]}
    />
    <p class="lead" style="margin-top:14px;font-size:.9rem">
      Источник: Мальцев С. В., Мансурова Г. Ш., Закирова А. М. и др.
      «Роль витамина D в системе мать — плацента — плод». Практическая
      медицина, 2016.
    </p>
  </Section>

  <CtaBand
    title="Пусть всегда будет солнце!"
    description="PantoVit — оптимальные D₃ и K₂ в одной формуле для крепких костей, здоровья сердца, иммунитета и репродуктивной системы."
  >
    <a href="/#contacts" class="btn btn-white">Где купить</a>
    <a href="/#products" class="btn btn-outline-white">Вся продукция</a>
  </CtaBand>
</BaseLayout>
