---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductHero from '../components/ProductHero.astro';
import PackCard from '../components/PackCard.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import FuncGrid from '../components/FuncGrid.astro';
import Compo from '../components/Compo.astro';
import Checklist from '../components/Checklist.astro';
import IndGroup from '../components/IndGroup.astro';
import IndList from '../components/IndList.astro';
import Split from '../components/Split.astro';
import InfoCard from '../components/InfoCard.astro';
import PromoBanner from '../components/PromoBanner.astro';
import CtaBand from '../components/CtaBand.astro';
import { products } from '../data/products';

const product = products.find((p) => p.slug === 'protektol-pan')!;
---
<BaseLayout
  theme={product.theme}
  active={product.slug}
  productDisclaimer
  title="Protektol-Pan — индол-3-карбинол и EGCG для гормонального баланса | PanPharm"
  description="Protektol-Pan — индол-3-карбинол 500 мг + катехины зелёного чая (EGCG) и эссенциальные фосфолипиды. Поддержка гормонального баланса, онкопротекция, защита репродуктивных органов у мужчин и женщин."
>
  <ProductHero
    product={product}
    badge="Индол-3-карбинол · EGCG · Фосфолипиды"
    slogan="«Защита и гормональный баланс»"
    description="Семикомпонентный комплекс: онкопротектор, фитоэстрогены, антиоксиданты, детоксиканты, гепатопротекторы. Поддерживает репродуктивное здоровье мужчин и женщин, нормализует гормональный фон."
    primary={{ href: '#sostav', label: 'Состав препарата' }}
    secondary={{ href: '#dozirovka', label: 'Как принимать' }}
  >
    <PackCard
      name="Protektol-Pan"
      sub="7 активных компонентов"
      items={[
        { name: 'Индол-3-карбинол',            value: '500 мг' },
        { name: 'Эпигаллокатехин-3-галлат',    value: '62 мг'  },
        { name: 'Эпикатехингаллат',             value: '17 мг'  },
        { name: 'Эпигаллокатехин',               value: '13 мг'  },
        { name: 'Эссенциальные фосфолипиды',    value: '75 мг'  },
      ]}
      form="Форма выпуска: 30 капсул"
      formIcon="pill"
    />
  </ProductHero>

  <PromoBanner
    image="/protektol-pan.jpeg"
    alt="Упаковка Protektol-Pan — 30 капсул"
    eyebrow="Protektol-Pan"
    title="Защита и гормональный баланс"
    description="Индол-3-карбинол, катехины зелёного чая и эссенциальные фосфолипиды — поддержка здоровья репродуктивных органов и онкопротекция."
  />

  <Section>
    <SectionHead
      center
      eyebrow="Главное"
      title="Универсальный комплекс пятого поколения"
      lead="Один состав работает в нескольких направлениях — от гормонального баланса до защиты от опухолевых процессов."
    />
    <FuncGrid
      cols={3}
      items={[
        { icon: 'scale',         title: 'Гормональный баланс', text: 'Нормализует метаболизм эстрогенов и помогает выровнять гормональный фон у женщин и мужчин.' },
        { icon: 'shield-check',  title: 'Онкопротекция',         text: 'Защищает клетки ДНК от повреждения, стимулирует апоптоз трансформированных клеток.' },
        { icon: 'leaf',          title: 'Антиоксидант · детокс', text: 'EGCG и катехины замедляют окислительные процессы, фосфолипиды поддерживают печень.' },
      ]}
    />
  </Section>

  <Section soft id="sostav">
    <SectionHead
      eyebrow="Состав"
      title="7 активных компонентов в 1 капсуле"
      lead="Индол-3-карбинол из крестоцветных + полная линейка катехинов зелёного чая (EGCG, EGC, ECG, EC, GCG) + эссенциальные фосфолипиды."
    />
    <Compo
      cols={2}
      items={[
        { value: '500 мг',  label: 'Индол-3-карбинол (I3C)'         },
        { value: '62 мг',   label: 'Эпигаллокатехин-3-галлат (EGCG)' },
        { value: '17 мг',   label: 'Эпикатехингаллат (ECG)'          },
        { value: '13 мг',   label: 'Эпигаллокатехин (EGC)'           },
        { value: '9,7 мг',  label: 'Эпикатехин (EC)'                  },
        { value: '7,4 мг',  label: 'Галлокатехингаллат (GCG)'         },
        { value: '75 мг',   label: 'Эссенциальные фосфолипиды'        },
      ]}
    />
    <div class="split" style="margin-top:36px">
      <InfoCard accent icon="sparkles" title="Чистая формула">
        <p style="color:var(--muted);margin-top:10px">
          <b>Оболочка капсулы не содержит:</b> диоксид титана и
          синтетические красители.
        </p>
        <p style="color:var(--muted);margin-top:10px">
          <b>Компоненты не содержат:</b> диоксид кремния, стеарат магния, МКЦ.
        </p>
      </InfoCard>
      <InfoCard icon="check-circle" title="Преимущества комплекса">
        <IndList
          style="margin-top:14px"
          items={[
            '7 эффективных компонентов: онкопротектор, фитоэстрогены, антиоксиданты, детоксиканты, гепатопротекторы',
            'Универсален: компенсирует и недостаток, и избыток эстрогенов',
            'Безопасен для профилактики и комплексного лечения',
            'Не даёт побочных эффектов',
          ]}
        />
      </InfoCard>
    </div>
  </Section>

  <Section>
    <SectionHead
      eyebrow="Показания к применению"
      title="Когда полезен Protektol-Pan"
      lead="Препарат назначают и в профилактических целях, и в составе комплексной терапии."
    />
    <IndGroup
      title="Женское здоровье"
      cols
      items={[
        'Поддержка гормонального баланса',
        'Снижение риска патологии молочных желёз',
        'Предотвращение формирования уплотнений',
        'Мастопатия и эндометриоз',
        'Уменьшение болезненности в груди',
        'Смягчение симптомов ПМС и менопаузы',
        'Профилактика остеопороза',
        'Гиперплазия эндометрия и фиброаденома',
      ]}
    />
    <IndGroup
      title="Мужское здоровье"
      cols
      items={[
        'В комплексной терапии аденомы простаты и простатита',
        'Профилактика рака предстательной железы',
        'Помощь в борьбе с ВПЧ и герпесом',
      ]}
    />
    <IndGroup
      title="Общая поддержка организма"
      cols
      items={[
        'Укрепление иммунной системы',
        'Активизация обменных процессов в печени',
        'Замедление процессов старения',
        'Выведение избытка эстрогенов',
        'Онкопротектор: толстая и прямая кишка, печень, простата, лёгкие',
        'Облегчение фибромиалгии (хронические мышечно-скелетные боли)',
      ]}
    />
  </Section>

  <Section soft id="dozirovka">
    <Split>
      <div slot="left">
        <span class="eyebrow">Способ применения и дозы</span>
        <h2>Как принимать Protektol-Pan</h2>
        <p class="lead" style="margin-top:14px">
          Принимать по <b>1 капсуле 2 раза в день</b>, желательно во время
          еды, запивая достаточным количеством воды.
        </p>
        <IndList
          style="margin-top:20px"
          items={[
            'Взрослые: 1 капсула × 2 раза в день',
            'Желательно — во время еды',
            'Запивать достаточным количеством воды',
            'Курс приёма определяется индивидуально',
          ]}
        />
      </div>
      <InfoCard slot="right" accent title="Кратко о приёме">
        <ul class="pack-list">
          <li><span>Суточная доза</span><b>2 капсулы</b></li>
          <li><span>Время приёма</span><b>во время еды</b></li>
          <li><span>Запивать</span><b>водой</b></li>
          <li><span>Форма выпуска</span><b>30 капсул</b></li>
        </ul>
      </InfoCard>
    </Split>
  </Section>

  <Section>
    <SectionHead
      center
      eyebrow="По направлениям"
      title="Что делает Protektol-Pan для женщин и мужчин"
    />
    <Split>
      <InfoCard slot="left" icon="user" title="Для женщин">
        <Checklist
          items={[
            'Нормализует метаболизм эстрогенов',
            'Уменьшает боль и дискомфорт при мастопатии и эндометриозе',
            'Предотвращает формирование уплотнений в молочных железах',
            'Снижает риск новообразований в груди и репродуктивных органах',
            'Нормализует гормональный фон',
            'Подавляет избыточный рост клеток',
            'Борется с воспалением',
            'Замедляет окислительные процессы и старение',
          ]}
        />
      </InfoCard>
      <InfoCard slot="right" icon="dumbbell" title="Для мужчин">
        <Checklist
          items={[
            'Тормозит разрастание клеток предстательной железы',
            'Защищает ДНК клеток от повреждения и химической интоксикации',
            'Блокирует развитие эстрогенных опухолей простаты',
            'Уменьшает воспаление в тканях простаты',
            'Стимулирует ферменты печени, нейтрализующие токсины',
            'Замедляет развитие вируса папилломы человека',
            'Активизирует апоптоз в опухолевых клетках',
            'Противоопухолевое действие на клетки толстой кишки',
          ]}
        />
      </InfoCard>
    </Split>
  </Section>

  <Section soft>
    <SectionHead
      center
      eyebrow="Клинические данные"
      title="Влияние на репродуктивное здоровье"
      lead="Исследование с участием 200 пациенток с функциональными кистами яичников — курс лечения 3 месяца."
    />
    <Checklist
      items={[
        'Уменьшение частоты рецидивов кист яичников',
        'Нормализация менструального цикла',
        'Восстановление репродуктивной функции',
        'Эффективная блокада сигнальных путей патологической пролиферации',
        'Стимуляция апоптоза трансформированных клеток',
        'Подавление патологического ангиогенеза',
      ]}
    />
    <p class="lead" style="margin-top:14px;font-size:.9rem">
      Источники: Адамян Л. В., Поддубный И. В., Глыбина Т. М. и др.
      «Лапароскопия при кистах яичника и брюшной полости у девочек». —
      М.: ГЭОТАР-Медиа, 2007. — 104 с.; Carcinogenesis, 2005; 264(4): 771–778.
    </p>
  </Section>

  <CtaBand
    title="Защита репродуктивного здоровья и гормонального баланса"
    description="Protektol-Pan — универсальный комплекс для профилактики и поддержки на любом этапе жизни. Безопасно, без побочных эффектов."
  >
    <a href="/#contacts" class="btn btn-white">Где купить</a>
    <a href="/#products" class="btn btn-outline-white">Вся продукция</a>
  </CtaBand>
</BaseLayout>
