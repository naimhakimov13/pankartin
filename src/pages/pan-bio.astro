---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductHero from '../components/ProductHero.astro';
import PackCard from '../components/PackCard.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import FuncGrid from '../components/FuncGrid.astro';
import Compo from '../components/Compo.astro';
import Checklist from '../components/Checklist.astro';
import DataTable from '../components/DataTable.astro';
import IndGroup from '../components/IndGroup.astro';
import IndList from '../components/IndList.astro';
import Split from '../components/Split.astro';
import InfoCard from '../components/InfoCard.astro';
import PromoBanner from '../components/PromoBanner.astro';
import CtaBand from '../components/CtaBand.astro';
import { products } from '../data/products';

const product = products.find((p) => p.slug === 'pan-bio')!;
---
<BaseLayout
  theme={product.theme}
  active={product.slug}
  productDisclaimer
  title="Pan-Bio — пробиотик с бифидо- и лактобактериями + инулин | PanPharm"
  description="Pan-Bio — синбиотик: Bifidobacterium BB-12, Lactobacillus rhamnosus GG и L. acidophilus с инулином. Лечение и профилактика дисбактериоза, поддержка при антибиотикотерапии. Для всей семьи с 2 лет."
>
  <ProductHero
    product={product}
    badge="Бифидобактерии · Лактобактерии · Инулин"
    slogan="«Здоровая микрофлора — для всей семьи»"
    description="Синбиотик с тремя клинически изученными штаммами и пребиотиком-инулином. Восстанавливает микрофлору кишечника, совместим с антибиотиками и безопасен с 2 лет."
    primary={{ href: '#sostav', label: 'Состав препарата' }}
    secondary={{ href: '#dozirovka', label: 'Как принимать' }}
  >
    <PackCard
      name="Pan-Bio"
      sub="Синбиотик · Для всей семьи"
      items={[
        { name: 'Bifidobacterium BB-12',     value: '12,2·10⁹ КОЕ' },
        { name: 'Lactobacillus rhamnosus GG', value: '2·10⁹ КОЕ'    },
        { name: 'L. acidophilus LA',          value: '5·10⁸ КОЕ'    },
        { name: 'Инулин',                     value: '≥ 720 мг'     },
      ]}
      form="Форма выпуска: 30 саше"
      formIcon="package"
    />
  </ProductHero>

  <PromoBanner
    image="/pan-bio.jpeg"
    alt="Упаковка Pan-Bio — 30 саше"
    eyebrow="Pan-Bio"
    title="Здоровая микрофлора для всей семьи"
    description="Три клинически изученных штамма пробиотиков и пребиотик-инулин — синбиотик для восстановления микрофлоры, поддержки иммунитета и работы на фоне антибиотиков."
  />

  <Section>
    <SectionHead
      center
      eyebrow="Главное"
      title="Что даёт Pan-Bio"
      lead="Три клинически изученных штамма пробиотиков и пребиотик-инулин — синергия для здоровой микрофлоры кишечника."
    />
    <FuncGrid
      cols={3}
      items={[
        { icon: 'shield',   title: 'Укрепляет иммунитет',       text: 'Активирует локальные макрофаги и повышает продукцию секреторного иммуноглобулина А.' },
        { icon: 'utensils', title: 'Улучшает пищеварение',      text: 'Способствует пищеварению и конкурирует с патогенами за питательные вещества.' },
        { icon: 'pill',     title: 'Совместим с антибиотиками', text: 'Снижает риск антибиотик-ассоциированной диареи на 42% и уменьшает побочные эффекты.' },
      ]}
    />
  </Section>

  <Section soft id="sostav">
    <SectionHead
      eyebrow="Состав"
      title="Содержание в одном саше"
      lead="Синбиотик — комбинация пробиотических бактерий и пребиотика, который служит для них питательной средой."
    />
    <Compo
      cols={2}
      items={[
        { value: '12,2·10⁹ КОЕ', label: 'Bifidobacterium BB-12'      },
        { value: '2·10⁹ КОЕ',    label: 'Lactobacillus rhamnosus GG' },
        { value: '5·10⁸ КОЕ',    label: 'Lactobacillus acidophilus LA' },
        { value: '≥ 720 мг',     label: 'Инулин (пребиотик)'          },
      ]}
    />
    <div class="split" style="margin-top:36px">
      <InfoCard accent title="Высокий профиль безопасности">
        <p style="color:var(--muted);margin-top:10px">
          Без побочных действий и противопоказаний — кроме индивидуальной
          непереносимости компонентов. Разрешён <b>взрослым и детям с 2 лет</b>,
          а также <b>беременным и кормящим женщинам</b>.
        </p>
      </InfoCard>
      <InfoCard title="Совместим с антибиотиками">
        <p style="color:var(--muted);margin-top:10px">
          Доказано повышает эффективность лечения и уменьшает побочные
          действия антибиотиков. Приём пробиотиков может помочь снизить риск
          развития диареи на фоне антибиотикотерапии <b>на 42%</b>.
        </p>
      </InfoCard>
    </div>
  </Section>

  <Section>
    <SectionHead
      eyebrow="Показания к применению"
      title="Когда назначают Pan-Bio"
      lead="Препарат применяется для лечения и профилактики дисбактериоза кишечника и связанных с ним нарушений пищеварения."
    />
    <IndGroup
      title="Дисбактериоз и нарушения пищеварения"
      cols
      items={[
        'Диарея (понос) и диспепсия',
        'Запоры у взрослых и детей с 2 лет',
        'Метеоризм (вздутие живота)',
        'Тошнота, отрыжка, рвота',
        'Боли в животе',
        'Аллергические кожные реакции',
      ]}
    />
    <IndGroup
      title="Инфекции желудочно-кишечного тракта"
      items={[
        'Вирусные и бактериальные инфекции ЖКТ (ротавирусная инфекция, диарея путешественника)',
        'В комплексной терапии и для профилактики диареи и метеоризма',
      ]}
    />
    <IndGroup
      title="Сопровождение терапии"
      items={[
        'На фоне антибиотиков широкого спектра действия и других противомикробных препаратов',
        'Дополнение к стандартной эрадикационной терапии Helicobacter pylori',
        'Лучевая терапия органов брюшной полости и малого таза',
      ]}
    />
  </Section>

  <Section soft id="dozirovka">
    <SectionHead
      eyebrow="Способ применения и дозы"
      title="Как принимать Pan-Bio"
      lead="Содержимое саше растворить в небольшом количестве воды, сока или йогурта."
    />
    <DataTable
      headers={['Возраст', 'Дозировка']}
      rows={[
        ['Дети от 2 лет и старше', '½ саше в день'],
        ['Взрослые',               '1–2 саше в день'],
        ['Беременные и кормящие',  '1 саше в день (после консультации со специалистом)'],
      ]}
    />
    <p class="lead" style="margin-top:14px;font-size:.92rem">
      Удобный приём: содержимое саше растворяется в небольшом количестве
      воды, сока или йогурта. Принимать во время еды или сразу после.
    </p>
  </Section>

  <Section>
    <SectionHead
      center
      eyebrow="Дисбактериоз"
      title="Факторы развития дисбактериоза"
      lead="Нарушение баланса микрофлоры кишечника может быть вызвано как внешними, так и внутренними причинами."
    />
    <Split>
      <InfoCard slot="left" title="Экзогенные факторы">
        <IndList
          style="margin-top:14px"
          items={[
            'Профессиональные (промышленные яды)',
            'Санитарно-гигиенические условия',
            'Физические и химические воздействия',
            'Ионизирующее излучение',
            'Климатогеографические факторы',
          ]}
        />
      </InfoCard>
      <InfoCard slot="right" title="Эндогенные факторы">
        <IndList
          style="margin-top:14px"
          items={[
            'Иммунные нарушения и стрессовые состояния',
            'Соматические и инфекционные заболевания',
            'Ишемия кишечника, ревматические болезни',
            'Сахарный диабет, пожилой возраст',
            'Нерациональное питание и голодание',
            'Медикаментозное воздействие',
          ]}
        />
      </InfoCard>
    </Split>
  </Section>

  <Section soft>
    <SectionHead
      center
      eyebrow="Механизм действия"
      title="Как работает Pan-Bio"
      lead="Пробиотические штаммы и инулин восстанавливают баланс микрофлоры и поддерживают защитные функции организма."
    />
    <FuncGrid
      cols={3}
      items={[
        { icon: 'bug',      title: 'Восстановление микрофлоры', text: 'Pan-Bio восстанавливает кишечную микрофлору у людей, получавших антибиотики.' },
        { icon: 'swords',   title: 'Конкуренция с патогенами',  text: 'Полезные бактерии вытесняют патогенные микроорганизмы и конкурируют с ними за питательные вещества.' },
        { icon: 'sparkles', title: 'Антиоксидантное действие',  text: 'Уничтожает супероксидные радикалы и снижает окислительный стресс.' },
      ]}
    />
    <Checklist
      items={[
        'Активирует локальные макрофаги и повышает презентацию антигена лимфоцитам',
        'Повышает продукцию секреторного иммуноглобулина А (sIgA)',
        'Снижает частоту стула при инфекционной диарее (пищевые отравления)',
        'Снижает риск антибиотик-ассоциированной диареи на 42%',
        'Конкурирует с патогенами за питательные вещества',
        'Уменьшает побочные эффекты антибиотикотерапии',
      ]}
    />
  </Section>

  <Section>
    <Split>
      <div slot="left">
        <span class="eyebrow">Связь кишечника и кожи</span>
        <h2>Кожные заболевания, индуцированные дисбиозом</h2>
        <p class="lead" style="margin-top:14px">
          Нарушение кишечной микробиоты запускает каскад воспалительных
          процессов, которые отражаются и на состоянии кожи.
        </p>
        <IndList
          style="margin-top:20px"
          items={[
            'Акне',
            'Атопический дерматит',
            'Псориаз',
            'Себорейный дерматит',
            'Незаживление ран',
            'Фотостарение и старение кожи',
            'Розацеа',
          ]}
        />
      </div>
      <div slot="right">
        <InfoCard title="Дисбиотическая кожа">
          <IndList
            style="margin-top:14px"
            items={[
              'Аномальная пролиферация и функция клеток кожи, нарушение пигментации',
              'Уменьшение количества коллагена, эластина и структурные нарушения в дерме',
              'Окислительный стресс и воспалительный ответ',
              'Нарушение иммунного гомеостаза',
              'Подавление ремоделирования ECM',
            ]}
          />
        </InfoCard>
        <div style="margin-top:20px">
          <InfoCard accent title="Здоровая кожа с Pan-Bio">
            <p style="color:var(--muted);margin-top:10px">
              Нормальная пролиферация и функции клеток кожи, нормальная
              пигментация, коллаген и эластин в норме, дермальные структуры
              без нарушений.
            </p>
          </InfoCard>
        </div>
      </div>
    </Split>
  </Section>

  <CtaBand
    title="Здоровая микрофлора — здоровье всей семьи"
    description="Pan-Bio восстанавливает баланс микрофлоры, поддерживает иммунитет и помогает при антибиотикотерапии. Безопасен с 2 лет, беременным и кормящим."
  >
    <a href="/#contacts" class="btn btn-white">Где купить</a>
    <a href="/#products" class="btn btn-outline-white">Вся продукция</a>
  </CtaBand>
</BaseLayout>
