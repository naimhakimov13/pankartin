---
interface Props {
  headers: string[];
  /** Row cells. Inner strings support inline HTML via set:html. */
  rows: string[][];
}
const { headers, rows } = Astro.props;
---
<div class="table-wrap">
  <table>
    <thead>
      <tr>{headers.map((h) => <th>{h}</th>)}</tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>{row.map((cell) => <td set:html={cell} />)}</tr>
      ))}
    </tbody>
  </table>
</div>
