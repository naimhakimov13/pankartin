---
import { Icon } from 'astro-icon/components';

interface Props {
  /** Lucide icon slug, e.g. "brain" → renders lucide:brain */
  icon: string;
  title: string;
}
const { icon, title } = Astro.props;
---
<div class="func">
  <div class="ico"><Icon name={`lucide:${icon}`} /></div>
  <h4>{title}</h4>
  <p><slot /></p>
</div>
