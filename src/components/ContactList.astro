---
import { Icon } from 'astro-icon/components';

interface ContactItem {
  /** Lucide icon slug, e.g. "phone" → renders lucide:phone */
  icon: string;
  label: string;
  value: string;
}

const items: ContactItem[] = [
  { icon: 'phone',   label: 'Телефон',      value: '+998 (__) ___-__-__'  },
  { icon: 'mail',    label: 'E-mail',       value: 'info@panpharm.uz'      },
  { icon: 'map-pin', label: 'Адрес',        value: 'г. Ташкент, Узбекистан'},
  { icon: 'clock',   label: 'Режим работы', value: 'Пн–Сб, 9:00 – 18:00'  },
];
---
<ul class="contact-list">
  {items.map((it) => (
    <li>
      <span class="ico"><Icon name={`lucide:${it.icon}`} /></span>
      <span><small>{it.label}</small><b>{it.value}</b></span>
    </li>
  ))}
</ul>
